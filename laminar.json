[
  {
    "name": "hello-service",
    "port": 8081,
    "binary": "./artifacts/hello",
    "cors": [
      "*"
    ],
    "methods": [
      "GET",
      "POST"
    ],
    "content_types": [
      "application/json"
    ],
    "allow_headers": [
      "Content-Type",
      "Authorization",
      "X-Api-Key"
    ],
    "expose_headers": [
      "X-Request-Id"
    ],
    "max_age": 3600,
    "allow_credentials": true,
    "response_mode": "lambda",
    "timeout": 30,
    "ignore_paths": [
      "/favicon.ico",
      "/.well-known/*"
    ],
    "env": {
      "LOG_LEVEL": "debug",
      "APP_ENV": "local"
    }
  }
]